   "source": [
    "# 🤖 NhaDat Chatbot - Sinh Q&A tổng hợp\n",
    "\n",
    "**Đọc `data.md` + `data/drive-extracted/` từ GitHub → Gemini sinh câu hỏi & trả lời → Push `data/qa-generated.md`**\n",
    "\n",
    "Kết quả: bot hiểu đúng hơn vì retrieval khớp với cách người thực hỏi.\n",
    "\n",
    "### Cách dùng:\n",
    "1. **Secrets (🔑 bên trái)** → thêm `GEMINI_API_KEY` và `GITHUB_TOKEN`\n",
    "2. **Runtime → Run all**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-1",
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 1: Cài thư viện\n",
    "!pip install -q requests\n",
    "print('✅ Sẵn sàng')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 2: Cấu hình\n",
    "import os, base64, time, requests, json, re\n",
    "from google.colab import userdata\n",
    "\n",
    "GITHUB_OWNER  = 'quang507'\n",
    "GITHUB_REPO   = 'NhaDat-chatbot'\n",
    "GITHUB_BRANCH = 'main'\n",
    "OUTPUT_FILE   = 'data/qa-generated.md'\n",
    "\n",
    "GEMINI_API_KEY = userdata.get('GEMINI_API_KEY')\n",
    "GITHUB_TOKEN   = userdata.get('GITHUB_TOKEN')\n",
    "\n",
    "GEMINI_URL = f'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={GEMINI_API_KEY}'\n",
    "\n",
    "print(f'🔑 Gemini: {\"✅\" if GEMINI_API_KEY else \"❌ CHƯA SET\"}')\n",
    "print(f'🔑 GitHub: {\"✅\" if GITHUB_TOKEN else \"❌ CHƯA SET\"}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 3: Tải dữ liệu từ GitHub\n",
    "GH_API = f'https://api.github.com/repos/{GITHUB_OWNER}/{GITHUB_REPO}'\n",
    "GH_HDR = {'Authorization': f'Bearer {GITHUB_TOKEN}', 'Accept': 'application/vnd.github+json'}\n",
    "\n",
    "def gh_get_text(path):\n",
    "    \"\"\"Tải file text từ GitHub, trả về nội dung hoặc None.\"\"\"\n",
    "    r = requests.get(f'{GH_API}/contents/{path}?ref={GITHUB_BRANCH}', headers=GH_HDR)\n",
    "    if not r.ok:\n",
    "        return None\n",
    "    data = r.json()\n",
    "    if isinstance(data, list):\n",
    "        return None  # là folder\n",
    "    content = data.get('content', '')\n",
    "    encoding = data.get('encoding', 'base64')\n",
    "    return base64.b64decode(content).decode('utf-8', errors='ignore')\n",
    "\n",
    "def gh_list_dir(path):\n",
    "    \"\"\"Liệt kê file trong folder GitHub.\"\"\"\n",
    "    r = requests.get(f'{GH_API}/contents/{path}?ref={GITHUB_BRANCH}', headers=GH_HDR)\n",
    "    if not r.ok:\n",
    "        return []\n",
    "    items = r.json()\n",
    "    if not isinstance(items, list):\n",
    "        return []\n",
    "    return [item for item in items if item['type'] == 'file' and item['name'].endswith('.md')]\n",
    "\n",
    "# Tải data.md\n",
    "sources = {}\n",
    "main_data = gh_get_text('data.md')\n",
    "if main_data:\n",
    "    sources['data.md'] = main_data\n",
    "    print(f'✅ data.md ({len(main_data):,} ký tự)')\n",
    "else:\n",
    "    print('⚠️ Chưa có data.md (sẽ dùng drive-extracted)')\n",
    "\n",
    "# Tải các file trong data/drive-extracted/\n",
    "drive_files = gh_list_dir('data/drive-extracted')\n",
    "for f in drive_files:\n",
    "    txt = gh_get_text(f['path'])\n",
    "    if txt:\n",
    "        sources[f['path']] = txt\n",
    "        print(f'✅ {f[\"path\"]} ({len(txt):,} ký tự)')\n",
    "    time.sleep(0.3)\n",
    "\n",
    "# Tải các file trong data/ (*.md)\n",
    "data_files = gh_list_dir('data')\n",
    "for f in data_files:\n",
    "    if f['path'] in sources:\n",
    "        continue\n",
    "    txt = gh_get_text(f['path'])\n",
    "    if txt:\n",
    "        sources[f['path']] = txt\n",
    "        print(f'✅ {f[\"path\"]} ({len(txt):,} ký tự)')\n",
    "    time.sleep(0.3)\n",
    "\n",
    "print(f'\\n📚 Tổng cộng {len(sources)} nguồn dữ liệu')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 4: Chia chunks\n",
    "CHUNK_SIZE = 1500\n",
    "OVERLAP    = 200\n",
    "\n",
    "def chunk_text(text, source_name):\n",
    "    \"\"\"Chia text thành chunks ~1500 ký tự, trả về list (source, chunk_text).\"\"\"\n",
    "    text = text.replace('\\r\\n', '\\n').strip()\n",
    "    if not text:\n",
    "        return []\n",
    "    blocks = re.split(r'\\n(?=#{1,6}\\s)|\\n\\s*\\n', text)\n",
    "    blocks = [b.strip() for b in blocks if b.strip()]\n",
    "    chunks = []\n",
    "    cur = ''\n",
    "    for b in blocks:\n",
    "        if len(b) > CHUNK_SIZE:\n",
    "            if cur:\n",
    "                chunks.append((source_name, cur))\n",
    "                cur = ''\n",
    "            for i in range(0, len(b), CHUNK_SIZE - OVERLAP):\n",
    "                chunks.append((source_name, b[i:i+CHUNK_SIZE]))\n",
    "            continue\n",
    "        if (cur + '\\n\\n' + b).__len__() > CHUNK_SIZE:\n",
    "            if cur:\n",
    "                chunks.append((source_name, cur))\n",
    "            cur = b\n",
    "        else:\n",
    "            cur = cur + '\\n\\n' + b if cur else b\n",
    "    if cur:\n",
    "        chunks.append((source_name, cur))\n",
    "    return chunks\n",
    "\n",
    "all_chunks = []\n",
    "for src, text in sources.items():\n",
    "    c = chunk_text(text, src)\n",
    "    all_chunks.extend(c)\n",
    "    print(f'  {src}: {len(c)} chunks')\n",
    "\n",
    "print(f'\\n✅ Tổng {len(all_chunks)} chunks cần sinh Q&A')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 5: Hàm sinh Q&A bằng Gemini\n",
    "QA_PROMPT = '''Bạn là chuyên viên tư vấn bất động sản dự án NyAh Phú Định (TP.HCM).\n",
    "Dựa trên đoạn văn bản sau, hãy tạo ra 5-8 cặp câu hỏi và trả lời mà khách hàng thực tế hay hỏi.\n",
    "\n",
    "YÊU CẦU:\n",
    "- Câu hỏi phải TỰ NHIÊN như khách hàng hỏi thật (không học thuật)\n",
    "- Trả lời NGẮN GỌN, ĐỦ Ý, dựa HOÀN TOÀN vào dữ liệu (không bịa)\n",
    "- Giữ nguyên MỌI SỐ LIỆU: diện tích, giá, mã căn/lô, tầng\n",
    "- Đa dạng: hỏi về giá, diện tích, tiện ích, chính sách, vị trí, thanh toán, pháp lý\n",
    "- Nếu đoạn văn không đủ dữ liệu thì sinh ít hơn (3-4 cặp)\n",
    "\n",
    "FORMAT OUTPUT (giữ đúng format này, mỗi cặp cách nhau 1 dòng trống):\n",
    "Q: [câu hỏi]\n",
    "A: [trả lời]\n",
    "\n",
    "ĐOẠN VĂN:\n",
    "{chunk}'''\n",
    "\n",
    "def gemini_qa(chunk_text, retry=4):\n",
    "    prompt = QA_PROMPT.format(chunk=chunk_text[:2000])\n",
    "    payload = {\n",
    "        'contents': [{'parts': [{'text': prompt}]}],\n",
    "        'generationConfig': {'temperature': 0.3, 'maxOutputTokens': 2048}\n",
    "    }\n",
    "    for i in range(retry):\n",
    "        try:\n",
    "            r = requests.post(GEMINI_URL, json=payload, timeout=60)\n",
    "            if r.status_code == 429:\n",
    "                w = (i + 1) * 20\n",
    "                print(f'    ⏳ rate limit {w}s')\n",
    "                time.sleep(w)\n",
    "                continue\n",
    "            r.raise_for_status()\n",
    "            return r.json()['candidates'][0]['content']['parts'][0]['text']\n",
    "        except Exception as e:\n",
    "            if i == retry - 1:\n",
    "                return ''\n",
    "            time.sleep(5)\n",
    "    return ''\n",
    "\n",
    "print('✅ Sẵn sàng sinh Q&A')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 6: Sinh Q&A từ tất cả chunks (có thể mất 30-60 phút)\n",
    "# Free tier: ~60 req/phút → 1s/request là an toàn\n",
    "qa_pairs = []  # list of (source, qa_text)\n",
    "errors   = 0\n",
    "\n",
    "for idx, (src, chunk) in enumerate(all_chunks):\n",
    "    if not chunk.strip():\n",
    "        continue\n",
    "    print(f'[{idx+1}/{len(all_chunks)}] {src[:50]}... ', end='')\n",
    "    qa = gemini_qa(chunk)\n",
    "    if qa.strip():\n",
    "        qa_pairs.append((src, chunk, qa))\n",
    "        n_pairs = qa.count('\\nQ:') + (1 if qa.startswith('Q:') else 0)\n",
    "        print(f'✅ {n_pairs} cặp Q&A')\n",
    "    else:\n",
    "        errors += 1\n",
    "        print('⚠️ (rỗng)')\n",
    "    time.sleep(1.2)  # ~50 req/phút, an toàn\n",
    "\n",
    "total_qa = sum(t.count('\\nQ:') + (1 if t.startswith('Q:') else 0) for _, _, t in qa_pairs)\n",
    "print(f'\\n✅ Xong! {len(qa_pairs)}/{len(all_chunks)} chunks → ~{total_qa} cặp Q&A ({errors} lỗi)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-7",
   "metadata": {},
   "outputs": [],
   "source": [
    "# CELL 7: Ghép thành file markdown + Push GitHub\n",
    "lines = [\n",
    "    '# Q&A Tổng hợp - NyAh Phú Định',\n",
    "    '',\n",
    "    f'> Tự động sinh từ {len(qa_pairs)} đoạn dữ liệu | {time.strftime(\"%Y-%m-%d %H:%M\")}',\n",
    "    ''\n",
    "]\n",
    "\n",
    "current_src = None\n",
    "for src, chunk, qa in qa_pairs:\n",
    "    if src != current_src:\n",
    "        lines.append(f'\\n## Nguồn: {src}\\n')\n",
    "        current_src = src\n",
    "    lines.append(qa.strip())\n",
    "    lines.append('')\n",
    "\n",
    "final_md = '\\n'.join(lines)\n",
    "print(f'📝 Tổng {len(final_md):,} ký tự')\n",
    "\n",
    "# Push lên GitHub\n",
    "if not GITHUB_TOKEN:\n",
    "    print('⚠️ Thiếu GITHUB_TOKEN')\n",
    "    print('Nội dung Q&A:')\n",
    "    print(final_md[:2000], '...')\n",
    "else:\n",
    "    url = f'{GH_API}/contents/{OUTPUT_FILE}'\n",
    "    r = requests.get(f'{url}?ref={GITHUB_BRANCH}', headers=GH_HDR)\n",
    "    sha = r.json().get('sha') if r.ok else None\n",
    "    body = {\n",
    "        'message': 'data: sinh Q&A tổng hợp từ Colab',\n",
    "        'branch': GITHUB_BRANCH,\n",
    "        'content': base64.b64encode(final_md.encode()).decode()\n",
    "    }\n",
    "    if sha:\n",
    "        body['sha'] = sha\n",
    "    r = requests.put(url, headers=GH_HDR, json=body)\n",
    "    if r.ok:\n",
    "        print(f'✅ Đã push → {OUTPUT_FILE}')\n",
    "        print('🔔 Về máy chạy Chay_Dong_Bo.bat để rebuild RAG index!')\n",
    "    else:\n",
    "        print(f'❌ Push lỗi: {r.status_code} {r.text[:200]}')"
   ]
  }
 ]
}"
